# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
# Local: mongodb://localhost:27017/voting_db
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/voting_db
MONGO_URI=mongodb://localhost:27017/voting_db

# JWT secret key — use a long random string in production!
JWT_SECRET=blockchain_voting_super_secret_key_2024

# Port for the backend server
PORT=5000

# React frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Smart contract address (update after deploying)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
